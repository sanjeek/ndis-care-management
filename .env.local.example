NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-for-server-invites
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000

# Email notifications via Resend (https://resend.com)
# Without these, all emails (worker invites, shift reminders, incident alerts) are silently skipped.
RESEND_API_KEY=re_your-resend-api-key
EMAIL_FROM=noreply@yourdomain.com
NOTIFICATION_EMAIL_TO=admin@yourdomain.com
ADMIN_NOTIFICATION_EMAIL=admin@yourdomain.com

# Cron job authentication (set this in Vercel env vars to secure /api/admin/backups/run and /api/notifications/shifts)
CRON_SECRET=your-random-secret-string

# Supabase Storage: create a bucket named "database-backups" in your Supabase project for the daily backup cron to work.
